<script>
// ═══════════════════════════════════════════════
// AUTO-SAVE
// ═══════════════════════════════════════════════
let autoSaveTimer;
const STORAGE_KEY = 'medtronic_dev_reg_draft';

function getAllFields() {
  const inputs = document.querySelectorAll('input, select, textarea');
  const data = {};
  inputs.forEach(el => {
    if (el.id) {
      if (el.type === 'checkbox' || el.type === 'radio') {
        data[el.id] = el.checked;
      } else {
        data[el.id] = el.value;
      }
    }
  });
  // Named radios
  ['rvPol','lvPol'].forEach(name => {
    const checked = document.querySelector(`input[name="${name}"]:checked`);
    data[`radio_${name}`] = checked ? checked.value : '';
  });
  return data;
}

function setAllFields(data) {
  Object.entries(data).forEach(([id, val]) => {
    if (id.startsWith('radio_')) {
      const name = id.replace('radio_', '');
      const radio = document.querySelector(`input[name="${name}"][value="${val}"]`);
      if (radio) radio.checked = true;
      return;
    }
    const el = document.getElementById(id);
    if (!el) return;
    if (el.type === 'checkbox' || el.type === 'radio') {
      el.checked = !!val;
    } else {
      el.value = val;
    }
  });
  // Update form number display
  const fn = document.getElementById('formNo');
  if (fn) document.getElementById('formNoVal').textContent = fn.value || '_____';
}

function triggerAutoSave() {
  clearTimeout(autoSaveTimer);
  const badge = document.getElementById('autosaveBadge');
  const text = document.getElementById('autosaveText');
  badge.classList.remove('saved');
  text.textContent = 'Saving...';
  autoSaveTimer = setTimeout(() => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(getAllFields()));
    badge.classList.add('saved');
    text.textContent = 'Auto-saved';
    setTimeout(() => {
      badge.classList.remove('saved');
      text.textContent = 'Draft';
    }, 3000);
  }, 800);
}

// Attach auto-save listeners
document.querySelectorAll('input, select, textarea').forEach(el => {
  el.addEventListener('input', triggerAutoSave);
  el.addEventListener('change', triggerAutoSave);
});

// ═══════════════════════════════════════════════
// SAVE / LOAD DRAFT
// ═══════════════════════════════════════════════
function saveDraft() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(getAllFields()));
  showToast('💾 Draft saved successfully', 'success');
}

function loadDraft() {
  const raw = localStorage.getItem(STORAGE_KEY);
  if (!raw) { showToast('No draft found', 'error'); return; }
  try {
    setAllFields(JSON.parse(raw));
    showToast('📂 Draft loaded', 'success');
  } catch(e) {
    showToast('Error loading draft', 'error');
  }
}

// Load on start
window.addEventListener('load', () => {
  const raw = localStorage.getItem(STORAGE_KEY);
  if (raw) {
    try { setAllFields(JSON.parse(raw)); } catch(e) {}
  }
});

// ═══════════════════════════════════════════════
// CLEAR FORM
// ═══════════════════════════════════════════════
function clearForm() {
  if (!confirm('ล้างข้อมูลทั้งหมด? (Draft จะถูกลบด้วย)')) return;
  document.querySelectorAll('input, select, textarea').forEach(el => {
    if (el.type === 'checkbox' || el.type === 'radio') el.checked = false;
    else el.value = '';
  });
  document.getElementById('formNoVal').textContent = '_____';
  localStorage.removeItem(STORAGE_KEY);
  showToast('🗑 Form cleared', 'success');
}

// ═══════════════════════════════════════════════
// CALC TOTAL
// ═══════════════════════════════════════════════
function calcTotal() {
  const priceIds = ['devPrice','raPrice','rvPrice','lvPrice','otherPrice'];
  let total = 0;
  priceIds.forEach(id => {
    const v = parseFloat(document.getElementById(id).value) || 0;
    total += v;
  });
  document.getElementById('totalThb').value = total.toLocaleString('th-TH', {minimumFractionDigits:2});
}

// ═══════════════════════════════════════════════
// VALIDATION
// ═══════════════════════════════════════════════
const REQUIRED = [
  { id: 'staffName', label: 'Medtronic Staff Name' },
  { id: 'implantDate', label: 'Implant Date' },
  { id: 'implantHospital', label: 'Implant Hospital' },
  { id: 'implanter', label: 'Implanter' },
  { id: 'nameTH', label: 'Patient Name (TH)' },
  { id: 'hn', label: 'HN' },
];

function validate() {
  const errors = [];
  document.querySelectorAll('input.invalid, select.invalid, textarea.invalid').forEach(el => {
    el.classList.remove('invalid');
  });

  REQUIRED.forEach(({id, label}) => {
    const el = document.getElementById(id);
    if (!el || !el.value.trim()) {
      errors.push(label);
      if (el) el.classList.add('invalid');
    }
  });

  const errorBox = document.getElementById('errorBox');
  const errorList = document.getElementById('errorList');
  if (errors.length > 0) {
    errorList.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
    errorBox.classList.add('visible');
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return false;
  } else {
    errorBox.classList.remove('visible');
    return true;
  }
}

// ═══════════════════════════════════════════════
// SUBMIT
// ═══════════════════════════════════════════════
function submitForm() {
  if (!validate()) return;
  const data = getAllFields();
  console.log('Form submitted:', data);
  showToast('✅ Form submitted successfully!', 'success');
  // In real integration: POST data to backend API here
}

// ═══════════════════════════════════════════════
// EXPORT PDF (print)
// ═══════════════════════════════════════════════
function exportPDF() {
  window.print();
}

// ═══════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════
let toastTimer;
function showToast(msg, type = '') {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.className = `toast ${type} show`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => {
    toast.classList.remove('show');
  }, 3000);
}
</script>

